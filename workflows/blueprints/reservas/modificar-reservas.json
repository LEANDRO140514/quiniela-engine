    {
      "parameters": {
        "jsCode": "// n8n Code node (JavaScript)\n// Siempre crea FechaInicio/FechaFin desde FechaActual (14:00 / 10:00, -03:00)\n// Mantiene FechaNuevaInicio/Final si ya vienen.\n// Genera FechaNuevaRango humano.\n\nconst FIXED_OFFSET = \"-03:00\";\n\nconst monthMap = {\n  'enero':1,'febrero':2,'marzo':3,'abril':4,'mayo':5,'junio':6,\n  'julio':7,'agosto':8,'septiembre':9,'setiembre':9,'octubre':10,\n  'noviembre':11,'diciembre':12,\n  'ene':1,'feb':2,'mar':3,'abr':4,'may':5,'jun':6,\n  'jul':7,'ago':8,'sep':9,'oct':10,'nov':11,'dic':12,\n};\nconst MONTHS_ES = ['', 'enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];\n\nconst norm = (s='') => s.toString().trim().toLowerCase().normalize('NFD').replace(/\\p{Diacritic}/gu,'');\nconst pad2 = n => String(n).padStart(2,'0');\nconst toISOFixed = (y,m,d,hh,mm,ss,offset) => `${y}-${pad2(m)}-${pad2(d)}T${pad2(hh)}:${pad2(mm)}:${pad2(ss)}${offset}`;\n\nfunction parseRangoDesdeTexto(textoRaw) {\n  const t = norm(textoRaw ?? '');\n  const now = new Date();\n  const yM = t.match(/(20\\d{2}|19\\d{2})/);\n  const year = yM ? parseInt(yM[1],10) : now.getFullYear();\n  const mKey = Object.keys(monthMap).find(k => t.includes(k));\n  const month = mKey ? monthMap[mKey] : null;\n  let r = t.match(/(?:\\bdel?\\s*)?(\\d{1,2})\\s*(?:al|-|a)\\s*(\\d{1,2})\\b/);\n  let s = null;\n  if (!r) s = t.match(/\\b(\\d{1,2})\\b/);\n  if (!month || (!r && !s)) return null;\n  let d1, d2;\n  if (r) { d1 = parseInt(r[1],10); d2 = parseInt(r[2],10); }\n  else   { d1 = parseInt(s[1],10);  d2 = d1; }\n  if (d2 < d1) [d1,d2] = [d2,d1];\n  return { year, month, d1, d2 };\n}\n\nfunction parseISODateOnly(iso) {\n  if (!iso) return null;\n  const m = String(iso).match(/^(\\d{4})-(\\d{2})-(\\d{2})/);\n  if (!m) return null;\n  return { y:+m[1], m:+m[2], d:+m[3] };\n}\n\nfunction formatRangeEs(a, b) {\n  if (!a || !b) return null;\n  const sameDay = a.y===b.y && a.m===b.m && a.d===b.d;\n  const sameMonth = a.y===b.y && a.m===b.m;\n  const mesA = MONTHS_ES[a.m], mesB = MONTHS_ES[b.m];\n  if (sameDay) return `el ${a.d} de ${mesA}`;\n  if (sameMonth) return `del ${a.d} al ${b.d} de ${mesA}`;\n  if (a.y === b.y) return `del ${a.d} de ${mesA} al ${b.d} de ${mesB}`;\n  return `del ${a.d} de ${mesA} de ${a.y} al ${b.d} de ${mesB} de ${b.y}`;\n}\n\nfor (const item of $input.all()) {\n  // 1) Siempre parsea FechaActual -> FechaInicio/FechaFin\n  const textoActual = item.json.FechaActual ?? item.json.FechaReserva ?? item.json.FechaNueva ?? '';\n  const r = parseRangoDesdeTexto(textoActual);\n  if (r) {\n    item.json.FechaInicio = toISOFixed(r.year, r.month, r.d1, 14, 0, 0, FIXED_OFFSET);\n    item.json.FechaFin    = toISOFixed(r.year, r.month, r.d2, 10, 0, 0, FIXED_OFFSET);\n  } else {\n    // no se pudo parsear -> deja nulos si no estaban\n    if (item.json.FechaInicio === undefined) item.json.FechaInicio = null;\n    if (item.json.FechaFin === undefined)    item.json.FechaFin    = null;\n  }\n\n  // 2) Texto humano: prioriza las nuevas; si no hay, usa las actuales\n  const startRaw = (item.json.FechaNuevaInicio ?? item.json.FechaInicio) || null;\n  const endRaw   = (item.json.FechaNuevaFinal  ?? item.json.FechaFin)   || null;\n  const a = parseISODateOnly(startRaw);\n  const b = parseISODateOnly(endRaw);\n  const rangoHumano = formatRangeEs(a, b);\n\n  item.json.FechaNuevaRango       = rangoHumano;\n  item.json.FechaNuevaInicioHuman = rangoHumano;\n  item.json.FechaNuevaFinalHuman  = rangoHumano;\n}\n\nreturn $input.all();"
      },
